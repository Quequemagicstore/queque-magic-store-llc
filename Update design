<!DOCTYPE html>
<html>
<head>
  <title>Queque Magic Store LLC</title>
  <style>
    body{
      font-family: Arial;
      margin:0;
      background:#f2f2f2;
    }

    header{
      background: linear-gradient(90deg, black, #333);
      color:white;
      text-align:center;
      padding:25px;
    }

    .subtitle{
      font-size:14px;
      opacity:0.8;
    }

    .products{
      display:flex;
      flex-wrap:wrap;
      justify-content:center;
      gap:20px;
      padding:20px;
    }

    .card{
      background:white;
      width:200px;
      border-radius:12px;
      padding:15px;
      text-align:center;
      box-shadow:0 2px 8px rgba(0,0,0,0.1);
    }

    .img{
      height:120px;
      background:#ddd;
      border-radius:10px;
      margin-bottom:10px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:12px;
      color:#666;
    }

    .price{
      font-weight:bold;
      margin:5px 0;
    }

    button{
      background:black;
      color:white;
      border:none;
      padding:8px 12px;
      border-radius:6px;
      cursor:pointer;
    }

    button:hover{
      background:#444;
    }

    .payment{
      background:white;
      margin:20px;
      padding:20px;
      border-radius:10px;
      text-align:center;
    }

    .footer{
      text-align:center;
      padding:15px;
      font-size:12px;
      color:#666;
    }
  </style>
</head>

<body>

<header>
  <h1>Queque Magic Store LLC</h1>
  <div class="subtitle">Sandal • Bijoux • Perfume • Fashion</div>
</header>

<div class="products">

  <div class="card">
    <div class="img">Sandal Photo</div>
    <h3>Sandal Luxury</h3>
    <div class="price">$35</div>
    <button>Buy Now</button>
  </div>

  <div class="card">
    <div class="img">Bijoux Photo</div>
    <h3>Bijoux Gold</h3>
    <div class="price">$20</div>
    <button>Buy Now</button>
  </div>

  <div class="card">
    <div class="img">Perfume Photo</div>
    <h3>Perfume Elegant</h3>
    <div class="price">$45</div>
    <button>Buy Now</button>
  </div>

  <div class="card">
    <div class="img">Outfit Photo</div>
    <h3>Shein Outfit</h3>
    <div class="price">$30</div>
    <button>Buy Now</button>
  </div>

</div>

<div class="payment">
  <h2>💳 Payment Methods</h2>
  <p>CashApp: <b>$quequemagicstorellc</b></p>
  <p>Zelle: <b>863-604-9855</b></p>
  <p>PayPal: <b>quequemagicstorellc@gmail.com</b></p>
</div>

<div class="footer">
  © 2026 Queque Magic Store LLC - All rights reserved
</div>

</body>
</html>
